    },
    "excludePaths": [
      "/docs/*",
      "/internal/*",
      "/webhooks/*"
    ],
    "excludeTags": [],
    "folderOverrides": {},
    "additionalVariables": []
  },
  "relativeRepoPath": "/Users/gavinkaepernick/Development/Code/STORD/parcel-service"
