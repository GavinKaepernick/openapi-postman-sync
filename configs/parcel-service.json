{
  "repoName": "parcel-service",
  "mixCommands": [
    "api_docs"
  ],
  "specFiles": {
    "parcel-service": "priv/documentation/parcel.open-api.yaml"
  },
  "environments": {
    "staging": {
      "name": "Staging",
      "baseUrl": "https://api.staging.parcel.stord.com"
    }
  },
  "customization": {
    "collectionName": "Parcel Service Demo",
    "disableQueryParams": true,
    "sortByName": true,
    "auth": {
      "type": "bearer",
      "tokenVariable": "BearerToken_Demo"
    },
    "headerDefaults": {
      "Accept": "application/json"
    },
    "excludePaths": [
      "/docs/*",
      "/internal/*",
      "/webhooks/*"
    ],
    "excludeTags": [],
    "folderOverrides": {},
    "additionalVariables": [
      {
        "key": "TESTVARIABLE",
        "value": "TESTING",
        "type": "string"
      },
      {
        "key": "STORD_VARIABLE",
        "value": "stord",
        "type": "string"
      }
    ]
  },
  "relativeRepoPath": "/Users/gavinkaepernick/Development/Code/STORD/parcel-service"
}